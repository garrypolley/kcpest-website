---
import { getCollection, render } from "astro:content";
import CallToAction from "../components/CallToAction.astro";
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import RequestServiceForm from "../components/RequestServiceForm.astro";
import ServiceGrid from "../components/ServiceGrid.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ id }) => id !== "home");
  const posts = await getCollection("posts");

  return [
    ...pages.map((page) => ({ params: { slug: page.id }, props: { entryType: "page", entry: page } })),
    ...posts.map((post) => ({ params: { slug: post.id }, props: { entryType: "post", entry: post } })),
  ];
}

const { entry, entryType } = Astro.props;
const { Content } = await render(entry);
const isProtectionPage = entryType === "page" && entry.id === "pest-protection-services";
const isRequestPage = entryType === "page" && entry.id === "pest-control-service";
const isServicesHubPage = entryType === "page" && entry.id === "pest-and-wildlife-services";
const isServiceDetailPage = entryType === "page" && entry.id.startsWith("pest-and-wildlife-services/");
const serviceLabels = new Set([
  "General Pest Control",
  "Bed Bug Extermination",
  "Termite Control",
  "Pre-Construction Termite",
  "Rodent Control",
  "Mosquito & Tick Control",
  "Spider Control",
  "Carpenter Ant Control",
  "Wildlife Control Services",
]);
const services = (await getCollection("pages"))
  .filter((page) => page.data.navLabel && serviceLabels.has(page.data.navLabel))
  .sort((a, b) => a.data.order - b.data.order);
const cleanTitle = (title: string) =>
  title
    .replace(/\s*\|\s*Kansas City,\s*MO\s*\|\s*KC Pest Experts\s*$/i, "")
    .replace(/\s*\|\s*KC Pest Experts\s*$/i, "")
    .trim();
const defaultPageOgImage = "/images/social/home-social-preview.png";
const defaultServiceOgImage = "/images/services/general-pest.jpg";
const pageOgImage =
  entryType === "page"
    ? isServiceDetailPage
      ? entry.data.previewImage ?? defaultServiceOgImage
      : isProtectionPage
        ? "/images/protection-plan-graphic.png"
        : defaultPageOgImage
    : defaultServiceOgImage;
const pageOgImageAlt =
  entryType === "page"
    ? entry.data.previewAlt ?? `${cleanTitle(entry.data.title)} service preview`
    : `${entry.data.title} article preview`;
---

{
  entryType === "page" ? (
    <Layout
      title={cleanTitle(entry.data.title)}
      description={entry.data.description}
      ogImage={pageOgImage}
      ogImageAlt={pageOgImageAlt}
      ogType="website"
    >
      <Hero title={cleanTitle(entry.data.title)} subtitle={entry.data.description} />
      <article class="article-content mx-auto max-w-3xl px-4 py-12 md:px-0">
        {
          isProtectionPage && (
            <figure class="mb-8 overflow-hidden rounded-2xl border border-brand-blue/10 bg-white p-3 shadow-sm">
              <img
                src="/images/protection-plan-graphic.png"
                alt="KC Pest Experts home protection program coverage graphic"
                class="h-auto w-full"
                loading="lazy"
              />
            </figure>
          )
        }
        {
          isServiceDetailPage && entry.data.previewImage && (
            <figure class="mb-8 h-56 overflow-hidden rounded-2xl border border-brand-blue/10 bg-white p-2 shadow-sm md:h-80">
              <img
                src={entry.data.previewImage}
                alt={entry.data.previewAlt ?? `${cleanTitle(entry.data.title)} preview`}
                class="h-full w-full object-cover object-center"
                loading="lazy"
              />
            </figure>
          )
        }
        <Content />
      </article>
      {isServicesHubPage && <ServiceGrid services={services} />}
      {isRequestPage ? <RequestServiceForm /> : <CallToAction />}
    </Layout>
  ) : (
    <Layout
      title={`${entry.data.title} | KC Pest Experts`}
      description={entry.data.description}
      canonicalPath={`/${entry.id}`}
      ogImage={pageOgImage}
      ogImageAlt={pageOgImageAlt}
      ogType="article"
    >
      <article class="article-content mx-auto max-w-3xl px-4 py-14 md:px-0">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">{entry.data.pubDate.toDateString()}</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight">{entry.data.title}</h1>
        <Content />
      </article>
      <CallToAction />
    </Layout>
  )
}
