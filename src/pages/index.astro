---
import { getCollection, getEntry } from "astro:content";
import CallToAction from "../components/CallToAction.astro";
import Hero from "../components/Hero.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import Layout from "../layouts/Layout.astro";

const home = await getEntry("pages", "home");
const services = (await getCollection("pages", ({ data }) => data.isService))
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Pest Control | Kansas City, MO | KC Pest Experts"
  description="Based in Kansas City, MO, KC Pest Experts provides expert pest control services for your home or business. Call (913) 600-5247 today to learn more!"
>
  <Hero
    title="Never worry about pests in your home or yard."
    subtitle="Expert pest control and home protection programs for the Kansas City metro area."
    ctaHref="/pest-protection-services"
    ctaLabel="View Protection Plans"
  />
  <ServiceGrid services={services} />
  <section class="section-shell pb-8">
    <div class="rounded-2xl border border-brand-blue/10 bg-white p-6 md:p-8">
      <h2 class="text-2xl font-bold">Local and licensed</h2>
      <p class="mt-3 text-slate-700">
        We are licensed and insured in both Kansas and Missouri. The team provides proactive prevention and responsive
        treatments for residential and commercial pest issues.
      </p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
        <span class="rounded-full bg-brand-blue/10 px-4 py-2 text-brand-blue">Kansas License #KS302495</span>
        <span class="rounded-full bg-brand-blue/10 px-4 py-2 text-brand-blue">Missouri License #MOC23735</span>
      </div>
    </div>
  </section>
  <CallToAction />
</Layout>
