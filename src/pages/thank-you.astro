---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Thank You | KC Pest Experts"
  description="Thanks for contacting KC Pest Experts. Our team will follow up with you shortly."
  noindex={true}
>
  <section class="section-shell py-16">
    <div class="mx-auto max-w-2xl rounded-2xl border border-brand-blue/10 bg-white p-8 text-center shadow-sm">
      <h1 class="text-4xl font-black">Thank you</h1>
      <p class="mt-3 text-slate-600">
        Your request was submitted. A KC Pest Experts team member will follow up shortly.
      </p>
      <a href="/" class="button-primary mt-6">Return Home</a>
    </div>
  </section>
</Layout>
