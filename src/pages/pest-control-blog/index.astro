---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout title="Pest Control Blog | KC Pest Experts" description="Pest education and prevention insights from KC Pest Experts.">
  <section class="mx-auto w-full max-w-4xl px-4 py-14 md:px-6">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Pest Control Blog</h1>
    <p class="mt-3 text-slate-600">Educational content migrated from the current site and kept in markdown for easy updates.</p>
    <div class="mt-10 space-y-4">
      {
        posts.map((post) => (
          <a href={`/pest-control-blog/${post.id}`} class="block rounded-lg border border-slate-200 bg-white p-5 transition hover:shadow-md">
            <p class="text-sm text-slate-500">{post.data.pubDate.toDateString()}</p>
            <h2 class="mt-1 text-xl font-semibold text-slate-900">{post.data.title}</h2>
            <p class="mt-2 text-sm text-slate-600">{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
