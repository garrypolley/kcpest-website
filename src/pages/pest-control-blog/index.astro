---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isPostPublicByPubDate } from "../../lib/postVisibility";

const posts = (await getCollection("posts"))
  .filter((p) => isPostPublicByPubDate(p.data.pubDate))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const formatPubDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  }).format(date);
---

<Layout
  title="Pest Control Blog | KC Pest Experts"
  description="Pest education and prevention insights from KC Pest Experts."
  ogImage="/images/services/general-pest.jpg"
  ogImageAlt="KC Pest Experts blog pest prevention insights"
  ogType="website"
>
  <section class="section-shell max-w-4xl py-14">
    <h1 class="text-4xl font-black tracking-tight">Pest Control Blog</h1>
    <p class="mt-3 text-slate-600">Educational content migrated from the current site and kept in markdown for easy updates.</p>
    <div class="mt-10 space-y-4">
      {
        posts.map((post) => (
          <a href={`/${post.id}`} class="block rounded-2xl border border-brand-blue/10 bg-white p-5 transition hover:shadow-md">
            {
              post.data.coverImage && (
                <div class="mb-4 overflow-hidden rounded-xl border border-brand-blue/10 bg-slate-100">
                  <img
                    src={post.data.coverImage}
                    alt={post.data.coverAlt ?? `${post.data.title} preview`}
                    class="h-40 w-full object-cover"
                    loading="lazy"
                  />
                </div>
              )
            }
            <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">{formatPubDate(post.data.pubDate)}</p>
            <h2 class="mt-1 text-xl font-bold">{post.data.title}</h2>
            <p class="mt-2 text-sm text-slate-600">{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
