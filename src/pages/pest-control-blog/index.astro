---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
  title="Pest Control Blog | KC Pest Experts"
  description="Pest education and prevention insights from KC Pest Experts."
  ogImage="/images/services/general-pest.jpg"
  ogImageAlt="KC Pest Experts blog pest prevention insights"
  ogType="website"
>
  <section class="section-shell max-w-4xl py-14">
    <h1 class="text-4xl font-black tracking-tight">Pest Control Blog</h1>
    <p class="mt-3 text-slate-600">Educational content migrated from the current site and kept in markdown for easy updates.</p>
    <div class="mt-10 space-y-4">
      {
        posts.map((post) => (
          <a href={`/${post.id}`} class="block rounded-2xl border border-brand-blue/10 bg-white p-5 transition hover:shadow-md">
            <p class="text-sm font-semibold uppercase tracking-wide text-brand-blue">{post.data.pubDate.toDateString()}</p>
            <h2 class="mt-1 text-xl font-bold">{post.data.title}</h2>
            <p class="mt-2 text-sm text-slate-600">{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
