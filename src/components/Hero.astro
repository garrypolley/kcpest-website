---
interface Props {
  title: string;
  subtitle?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { title, subtitle, ctaHref = "/pest-control-service#request-form", ctaLabel = "Request Service" } = Astro.props;
---

<section class="bg-gradient-to-br from-blue-950 via-blue-900 to-sky-700 text-white">
  <div class="section-shell grid gap-10 py-16 md:grid-cols-2 md:items-center md:py-20">
    <div>
      <p class="inline-flex rounded-md border border-blue-200/45 bg-white/8 px-3 py-1 text-sm font-semibold uppercase tracking-[0.2em] text-blue-100">
        Real Problems - Expert Solutions
      </p>
      <p class="mt-4 inline-flex rounded-full border border-brand-gold/55 bg-brand-blue/35 px-5 py-2 text-xs font-bold uppercase tracking-[0.15em] text-brand-gold">
        Licensed in Kansas & Missouri
      </p>
      <h1 class="mt-5 max-w-3xl text-4xl font-black leading-tight tracking-tight text-white md:text-5xl">{title}</h1>
      {subtitle && <p class="mt-5 max-w-2xl text-lg text-blue-100">{subtitle}</p>}
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={ctaHref} class="button-primary">{ctaLabel}</a>
        <a
          href="tel:+19136005247"
          class="inline-flex items-center rounded-full border border-white/40 px-5 py-3 text-sm font-semibold text-white transition hover:border-white hover:bg-white/10"
        >
          Call (913) 600-5247
        </a>
      </div>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/10 p-6 shadow-2xl backdrop-blur">
      <h2 class="text-xl font-bold text-white">Home Protection Program</h2>
      <p class="mt-3 text-sm text-blue-100">
        Seasonal and year-round treatments for common Kansas City pests including rodents, termites, spiders, mosquitoes, and more.
      </p>
      <ul class="mt-5 space-y-2 text-sm text-blue-100">
        <li>• Responsive scheduling and follow-up</li>
        <li>• Family-focused treatment planning</li>
        <li>• Service coverage across the KC metro</li>
      </ul>
    </div>
  </div>
</section>
