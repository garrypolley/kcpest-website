---
interface Props {
  title: string;
  subtitle?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { title, subtitle, ctaHref = "/pest-control-service", ctaLabel = "Request Service" } = Astro.props;
---

<section class="bg-gradient-to-br from-blue-950 via-blue-900 to-sky-700 text-white">
  <div class="mx-auto w-full max-w-6xl px-4 py-20 md:px-6 md:py-24">
    <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight md:text-5xl">{title}</h1>
    {subtitle && <p class="mt-5 max-w-2xl text-lg text-blue-100">{subtitle}</p>}
    <a
      href={ctaHref}
      class="mt-8 inline-flex rounded-md bg-white px-5 py-3 text-sm font-semibold text-blue-900 transition hover:bg-blue-50"
    >
      {ctaLabel}
    </a>
  </div>
</section>
