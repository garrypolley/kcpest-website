---
/**
 * Official lockup from CDN (mirrored locally):
 * https://lirp.cdn-website.com/49c37343/dms3rep/multi/opt/KC-pest-expert-kansas-city-logo-218w.webp
 * Dimensions: 178×52 (same as historical public/images/logo.webp).
 */
const LOGO_SRC = "/images/brand/kc-pest-header-logo.webp";
const LOGO_W = 178;
const LOGO_H = 52;
---

<img
  src={LOGO_SRC}
  alt=""
  width={LOGO_W}
  height={LOGO_H}
  class="h-12 w-auto shrink-0"
  loading="eager"
  decoding="async"
  aria-hidden="true"
/>
