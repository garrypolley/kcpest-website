---
/**
 * Pixel-accurate header mark: raster only (matches kc-pest-header-logo.png exactly).
 * SVG approximations diverge; the shipped PNG is the source of truth.
 */
const LOGO_SRC = "/images/brand/kc-pest-header-logo.png";
const LOGO_W = 458;
const LOGO_H = 224;
---

<img
  src={LOGO_SRC}
  alt=""
  width={LOGO_W}
  height={LOGO_H}
  class="h-12 w-auto shrink-0"
  loading="eager"
  decoding="async"
  aria-hidden="true"
/>
