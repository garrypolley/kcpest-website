---
/**
 * Official raster lockup (178×52 WebP from CDN, mirrored locally).
 */
const LOGO_SRC = "/images/brand/kc-pest-header-logo.webp";
const LOGO_W = 178;
const LOGO_H = 52;
---

<img
  src={LOGO_SRC}
  alt=""
  width={LOGO_W}
  height={LOGO_H}
  class="h-12 w-auto shrink-0"
  loading="eager"
  decoding="async"
  aria-hidden="true"
/>
