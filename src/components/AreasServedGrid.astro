---
interface LocationItem {
  id: string;
  data: {
    title: string;
    description?: string;
    city?: string;
    state?: string;
    population?: number;
    previewImage?: string;
    previewAlt?: string;
  };
}

interface Props {
  locations: LocationItem[];
}

const { locations } = Astro.props;
---

<section class="section-shell pb-16">
  <h2 class="text-3xl font-black md:text-4xl">Kansas City Metro Areas Served</h2>
  <p class="mt-2 max-w-3xl text-slate-600">
    Explore city-specific pages with local pest pressure insights, recommended service priorities, and quick access to request service.
  </p>
  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      locations.map((location) => (
        <a
          href={`/${location.id}`}
          class="group rounded-2xl border border-brand-blue/10 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
        >
          <div class="mb-4 overflow-hidden rounded-xl border border-brand-blue/10 bg-slate-100">
            <img
              src={location.data.previewImage ?? "/images/social/home-social-preview.png"}
              alt={location.data.previewAlt ?? `${location.data.city ?? "Service area"} preview`}
              class="h-32 w-full object-cover transition duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
          </div>
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-blue">
            {location.data.city}, {location.data.state}
          </p>
          <h3 class="mt-1 text-lg font-bold text-brand-ink">{location.data.city} Pest & Wildlife Services</h3>
          <p class="mt-2 text-sm text-slate-600">{location.data.description}</p>
          {
            location.data.population && (
              <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-slate-500">
                Population {location.data.population.toLocaleString()}
              </p>
            )
          }
        </a>
      ))
    }
  </div>
</section>
