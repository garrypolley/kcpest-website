---
interface ServiceItem {
  slug: string;
  data: {
    title: string;
    description?: string;
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-6">
  <h2 class="text-2xl font-bold text-slate-900 md:text-3xl">Core Pest Control Services</h2>
  <p class="mt-2 max-w-3xl text-slate-600">
    Built from your existing website structure so pages can be iterated without changing routes.
  </p>
  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <a href={`/${service.slug}`} class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <h3 class="font-semibold text-slate-900">{service.data.title}</h3>
          <p class="mt-2 text-sm text-slate-600">
            {service.data.description ?? "Learn more about this service and request a quote."}
          </p>
        </a>
      ))
    }
  </div>
</section>
