---
interface ServiceItem {
  id: string;
  data: {
    title: string;
    description?: string;
    previewImage?: string;
    previewAlt?: string;
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
const cleanTitle = (title: string) =>
  title
    .replace(/\s*\|\s*Kansas City,\s*MO\s*\|\s*KC Pest Experts\s*$/i, "")
    .replace(/\s*\|\s*KC Pest Experts\s*$/i, "")
    .trim();
---

<section class="section-shell py-14">
  <h2 class="text-3xl font-black md:text-4xl">Pest and Wildlife Services</h2>
  <p class="mt-2 max-w-3xl text-slate-600">
    Proven treatment plans and prevention programs across the Kansas City metro area.
  </p>
  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      services.map((service) => (
        <a href={`/${service.id}`} class="group rounded-2xl border border-brand-blue/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
          <div class="mb-4 overflow-hidden rounded-xl border border-brand-blue/10 bg-slate-100">
            <img
              src={service.data.previewImage ?? "/images/brand/kc-pest-mark.svg"}
              alt={service.data.previewAlt ?? `${cleanTitle(service.data.title)} preview`}
              class="h-28 w-full object-cover transition duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
          </div>
          <p class="mb-4 inline-flex rounded-full bg-brand-blue/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-brand-blue">
            Service
          </p>
          <h3 class="font-bold text-brand-ink transition group-hover:text-brand-blue">{cleanTitle(service.data.title)}</h3>
          <p class="mt-2 text-sm text-slate-600">
            {service.data.description ?? "Learn more about this service and request a quote."}
          </p>
          <p class="mt-4 text-sm font-semibold text-brand-blue">Learn more →</p>
        </a>
      ))
    }
  </div>
</section>
