---
import "../styles/global.css";
import SiteLogo from "../components/SiteLogo.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title = "Pest Control | Kansas City, MO | KC Pest Experts",
  description = "Based in Kansas City, MO, KC Pest Experts provides expert pest control services for your home or business. Call (913) 600-5247 today to learn more!",
  canonicalPath,
  ogImage = "/images/social/home-social-preview.png",
  ogImageAlt = "KC Pest Experts trusted pest and wildlife control in Kansas City",
  ogType = "website",
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://kcpest-website.garrypolley.com");
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robots = noindex ? "noindex, nofollow" : "index, follow";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "KC Pest Experts",
  image: [ogImageUrl],
  url: siteUrl.toString(),
  telephone: "+1-913-600-5247",
  sameAs: [
    "https://yelp.com/biz/kc-pest-experts-olathe",
    "https://facebook.com/profile.php?id=100083075783752",
    "https://instagram.com/kcpestexperts/",
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: "2001 East Prairie Circle, Unit B",
    addressLocality: "Olathe",
    addressRegion: "KS",
    postalCode: "66062",
    addressCountry: "US",
  },
  areaServed: "Kansas City Metro",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Semi+Condensed:wght@700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="KC Pest Experts" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </head>
  <body class="bg-brand-cream text-slate-800">
    <header class="sticky top-0 z-30 border-b border-brand-blue/10 bg-white/95 backdrop-blur">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6 px-4 py-4 md:px-6">
        <a href="/" class="flex items-center" aria-label="KC Pest Experts Home">
          <SiteLogo />
        </a>
        <details class="relative md:hidden">
          <summary class="list-none cursor-pointer rounded-lg border border-brand-blue/20 px-3 py-2 text-sm font-semibold text-brand-blue">
            Menu
          </summary>
          <nav class="absolute right-0 top-full z-50 mt-2 w-[20rem] rounded-xl border border-brand-blue/10 bg-white p-2 shadow-xl">
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-ink hover:bg-brand-cream" href="/">Home</a>
            <details class="rounded-lg">
              <summary class="list-none cursor-pointer rounded-lg px-3 py-2 text-sm font-semibold text-brand-ink hover:bg-brand-cream">
                Pest and Wildlife Services
              </summary>
              <div class="mt-1 space-y-1 pl-2">
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/local-pest-control-experts">General Pest Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/bed-bug-service">Bed Bug Extermination</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/termite-control-service">Termite Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/pre-construction-termite-treatments">Pre-Construction Termite Treatments</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/rodent-pest-control-service">Rodent Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/mosquitos-ticks-pest-control">Mosquito & Tick Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/spider-pest-control-service">Spider Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/carpenter-ants-pest-control">Carpenter Ant Control</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/wildlife-control-services">Wildlife Control Services</a>
                <a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-cream" href="/pest-and-wildlife-services/attic-disinfectant-insulation-cleanup">Attic Disinfectant &amp; Insulation Cleanup</a>
              </div>
            </details>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-ink hover:bg-brand-cream" href="/pest-protection-services">Protection Plans</a>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-ink hover:bg-brand-cream" href="/pest-control-blog">Blog</a>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-blue hover:bg-brand-cream" href="tel:+19136005247">Call (913) 600-5247</a>
            <a class="mt-1 block rounded-lg bg-brand-gold px-3 py-2 text-sm font-semibold text-brand-ink hover:bg-brand-gold-dark" href="/pest-control-service#request-form">Request Service</a>
          </nav>
        </details>
        <nav class="hidden items-center gap-5 text-sm font-semibold text-brand-ink md:flex">
          <a class="transition hover:text-brand-blue" href="/">Home</a>
          <div class="group relative">
            <a class="transition hover:text-brand-blue focus:text-brand-blue" href="/pest-and-wildlife-services">Pest and Wildlife Services</a>
            <div class="invisible absolute left-0 top-full z-40 w-80 rounded-xl border border-brand-blue/10 bg-white p-2 opacity-0 shadow-xl transition duration-150 pointer-events-none -translate-y-1 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100 group-focus-within:translate-y-0">
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/local-pest-control-experts">General Pest Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/bed-bug-service">Bed Bug Extermination</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/termite-control-service">Termite Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/pre-construction-termite-treatments">Pre-Construction Termite Treatments</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/rodent-pest-control-service">Rodent Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/mosquitos-ticks-pest-control">Mosquito & Tick Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/spider-pest-control-service">Spider Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/carpenter-ants-pest-control">Carpenter Ant Control</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/wildlife-control-services">Wildlife Control Services</a>
              <a class="block rounded-lg px-3 py-2 hover:bg-brand-cream" href="/pest-and-wildlife-services/attic-disinfectant-insulation-cleanup">Attic Disinfectant &amp; Insulation Cleanup</a>
            </div>
          </div>
          <a class="transition hover:text-brand-blue" href="/pest-protection-services">Protection Plans</a>
          <a class="transition hover:text-brand-blue" href="/pest-control-blog">Blog</a>
          <a class="transition text-brand-blue hover:text-brand-blue-light" href="tel:+19136005247">(913) 600-5247</a>
          <a class="inline-flex rounded-full bg-brand-gold px-4 py-2 text-brand-ink transition hover:bg-brand-gold-dark" href="/pest-control-service#request-form">Request Service</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-brand-blue/10 bg-white">
      <div class="mx-auto w-full max-w-6xl px-4 pt-8 md:px-6">
        <a
          href="/pest-control-service-areas"
          class="grid gap-4 rounded-2xl border border-brand-blue/10 bg-brand-cream/60 p-5 transition hover:shadow-md md:grid-cols-[1.25fr_1fr] md:items-center"
        >
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-blue">Areas Served</p>
            <h3 class="mt-1 text-lg font-bold text-brand-ink">Explore City-Specific KC Metro Service Pages</h3>
            <p class="mt-2 text-sm text-slate-600">
              View service-area cards, local pest trends, and neighborhood-specific recommendations.
            </p>
            <p class="mt-2 text-xs text-slate-500">KC metro county map included for quick service-area context.</p>
          </div>
          <div class="overflow-hidden rounded-xl border border-brand-blue/10 bg-white p-2">
            <img
              src="/images/maps/kc-metro-map.svg"
              alt="Kansas City metropolitan area county map"
              class="h-36 w-full object-contain md:h-28"
              loading="lazy"
            />
          </div>
        </a>
      </div>
      <div class="mx-auto grid w-full max-w-6xl gap-6 px-4 py-10 md:grid-cols-3 md:px-6">
        <div>
          <h3 class="font-semibold text-brand-blue">KC Pest Experts</h3>
          <p class="mt-2 text-sm text-slate-600">
            2001 East Prairie Circle, Unit B<br />
            Olathe, Kansas 66062
          </p>
        </div>
        <div class="text-sm text-slate-600">
          <p class="font-semibold text-brand-blue">Contact</p>
          <p class="mt-2">Phone: (913) 600-5247</p>
          <p>Mon - Fri 8:00 am - 5:00 pm</p>
          <p>Available by Phone 24/7</p>
        </div>
        <div class="text-sm text-slate-600">
          <p class="font-semibold text-brand-blue">Licensing</p>
          <p class="mt-2">Kansas License #KS302495</p>
          <p>Missouri License #MOC23735</p>
          <p>Licensed &amp; Insured in Kansas &amp; Missouri</p>
        </div>
      </div>
    </footer>
    <div class="fixed inset-x-0 bottom-0 z-40 border-t border-brand-blue/10 bg-white/95 p-3 backdrop-blur md:hidden">
      <div class="mx-auto flex max-w-6xl gap-2">
        <a
          href="tel:+19136005247"
          class="flex-1 rounded-full border border-brand-blue/20 px-4 py-2 text-center text-sm font-semibold text-brand-blue"
        >
          Call Now
        </a>
        <a
          href="/pest-control-service#request-form"
          class="flex-1 rounded-full bg-brand-gold px-4 py-2 text-center text-sm font-semibold text-brand-ink"
        >
          Request Service
        </a>
      </div>
    </div>
  </body>
</html>
